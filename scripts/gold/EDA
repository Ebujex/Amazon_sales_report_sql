------Monthly Revenue Analysis Excluding Cancelled Orders----
SELECT 
	order_month,
	SUM(amount) AS revenue
FROM
	(SELECT
		order_month,
		amount
	FROM 
		gold.amazon_sales
	WHERE
		status <> 'Cancelled')t
GROUP BY
	order_month
ORDER BY
	SUM(amount) DESC
/* Insight: the highest revenue was made in April, while the least was made in march */


