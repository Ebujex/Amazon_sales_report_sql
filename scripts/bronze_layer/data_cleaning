/*
=========================================================
Data Cleaning and Transformation
=========================================================
Purpose:
This script documents the main cleaning and transformation
steps applied to the raw Amazon sales dataset in the bronze
layer before creating the cleaned silver layer.

Transformations Included:
- Duplicate handling using ROW_NUMBER()
- Order status standardization
- NULL handling
- Amount rounding
- Ship city normalization
- Ship state standardization
- Fulfilled_by missing value handling
=========================================================
*/


/* Deduplicate repeated order and SKU combinations, keeping the row with the highest amount */
WITH row_num AS (
    SELECT
        *,
        ROW_NUMBER() OVER (
            PARTITION BY order_id, sku
            ORDER BY amount DESC
        ) AS order_rank
    FROM bronze.amazon_sales
)
SELECT
    *
FROM row_num
WHERE order_rank = 1;


/* Standardize detailed shipped status into a simplified shipped status */
SELECT
    status,
    CASE
        WHEN status = 'Shipped - Delivered to Buyer' THEN 'Shipped'
        ELSE status
    END AS status_clean
FROM bronze.amazon_sales;


/* Replace missing amount values with 0 and round amount to the nearest ten */
SELECT
    amount,
    ROUND(COALESCE(amount, 0), -1) AS amount_clean
FROM bronze.amazon_sales;


/* Normalize ship city values by standardizing casing, trimming spaces, and handling common city name variations */
SELECT DISTINCT
    CASE
        WHEN ship_city IS NULL THEN 'UNKNOWN'
        WHEN UPPER(TRIM(ship_city)) LIKE '%MUMBAI%' THEN 'MUMBAI'
        WHEN UPPER(TRIM(ship_city)) LIKE '%COCHIN%' THEN 'COCHIN'
        WHEN UPPER(TRIM(ship_city)) LIKE '%HOWRAH%' THEN 'HOWRAH'
        WHEN UPPER(TRIM(ship_city)) LIKE '%SURYAPET%' THEN 'SURYAPET'
        WHEN UPPER(TRIM(ship_city)) LIKE '%DIST%'
             AND CHARINDEX(' ', UPPER(TRIM(ship_city))) > 0
            THEN LEFT(UPPER(TRIM(ship_city)), CHARINDEX(' ', UPPER(TRIM(ship_city))) - 1)
        WHEN UPPER(TRIM(ship_city)) LIKE '%.%'
            THEN LEFT(UPPER(TRIM(ship_city)), CHARINDEX('.', UPPER(TRIM(ship_city))) - 1)
        WHEN UPPER(TRIM(ship_city)) LIKE '%-%'
            THEN LEFT(UPPER(TRIM(ship_city)), CHARINDEX('-', UPPER(TRIM(ship_city))) - 1)
        WHEN UPPER(TRIM(ship_city)) LIKE '%,%'
            THEN SUBSTRING(
                UPPER(TRIM(ship_city)),
                CHARINDEX(',', UPPER(TRIM(ship_city))) + 1,
                LEN(UPPER(TRIM(ship_city)))
            )
        ELSE UPPER(TRIM(ship_city))
    END AS ship_city_clean
FROM bronze.amazon_sales;


/* Standardize ship state values by expanding selected state abbreviations and handling missing values */
SELECT DISTINCT
    CASE
        WHEN ship_state IS NULL THEN 'UNKNOWN'
        WHEN UPPER(TRIM(ship_state)) IN ('RJ', 'RAJ') THEN 'RAJASTHAN'
        WHEN UPPER(TRIM(ship_state)) = 'AR' THEN 'ARUNACHAL PRADESH'
        WHEN UPPER(TRIM(ship_state)) = 'NL' THEN 'NAGALAND'
        WHEN UPPER(TRIM(ship_state)) = 'PB' THEN 'PUNJAB'
        ELSE UPPER(TRIM(ship_state))
    END AS ship_state_clean
FROM bronze.amazon_sales;


/* Replace missing fulfilled_by values with N/A */
SELECT DISTINCT
    COALESCE(fulfilled_by, 'N/A') AS fulfilled_by_clean
FROM bronze.amazon_sales;
