/*
=========================================================
Silver Layer Transformation
=========================================================
Purpose:
This script prepares the cleaned Amazon sales data for
analysis by adding useful reporting fields and grouping
detailed order statuses into broader business categories.

Transformations Included:
- Month name extraction from order date
- Order status categorization for analysis
=========================================================
*/


/* Create a month column from the order date */
SELECT
    order_date,
    DATENAME(MONTH, order_date) AS order_month
FROM silver.amazon_sales
ORDER BY order_date;


/* Group detailed order statuses into business-friendly status categories */
SELECT
    CASE
        WHEN status IN (
            'Shipped - Lost in Transit',
            'Shipped - Returning to Seller',
            'Shipped - Returned to Seller',
            'Shipped - Rejected by Buyer',
            'Shipped - Damaged'
        ) THEN 'Returned/Failed'

        WHEN status IN (
            'Pending',
            'Pending - Waiting for Pick Up',
            'Shipping'
        ) THEN 'Pending'

        WHEN status IN (
            'Shipped - Picked Up',
            'Shipped - Out for Delivery',
            'Shipped'
        ) THEN 'Shipped'

        ELSE 'Cancelled'
    END AS status_group,
    amount
FROM silver.amazon_sales;
