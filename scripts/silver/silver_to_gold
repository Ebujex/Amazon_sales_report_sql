/* inserting the transformed silver data into gold table */

WITH sales_data AS 
	( SELECT
		[index],
		order_id,
		order_date,
		DATENAME(MONTH,order_date) AS order_month,
		CASE
			WHEN status IN ('Shipped - Lost in Transit',
			'Shipped - Returning to Seller',
			'Shipped - Returned to Seller',
			'Shipped - Rejected by Buyer',
			'Shipped - Damaged') THEN 'Returned/Failed'
			WHEN status IN ('Pending',
			'Pending - Waiting for Pick Up',
			'Shipping') THEN 'Pending'
			WHEN status IN ('Shipped - Picked Up',
			'Shipped - Out for Delivery',
			'Shipped') THEN 'Shipped'
		ELSE
			'Cancelled'
		END AS status,
		fulfilment,
		sales_Channel,
		ship_service_level,
		style,
		sku,
		category,
		size,
		asin,
		courier_status,
		CAST(qty AS INT) AS qty,
		currency,
		amount,
		ship_city,
		ship_state,
		ship_postal_code,
		ship_country,
		b2b,
		fulfilled_by
FROM
	silver.amazon_sales
	)
INSERT INTO gold.amazon_sales
SELECT
		[index],
		order_id,
		order_date,
		DATENAME(MONTH,order_date) AS order_month,
		CASE
			WHEN [status] IN ('Shipped - Lost in Transit',
			'Shipped - Returning to Seller',
			'Shipped - Returned to Seller',
			'Shipped - Rejected by Buyer',
			'Shipped - Damaged') THEN 'Returned/Failed'
			WHEN [status] IN ('Pending',
			'Pending - Waiting for Pick Up',
			'Shipping') THEN 'Pending'
			WHEN [status] IN ('Shipped - Picked Up',
			'Shipped - Out for Delivery',
			'Shipped') THEN 'Shipped'
		ELSE
			'Cancelled'
		END AS status_main,
		fulfilment,
		sales_Channel,
		ship_service_level,
		style,
		sku,
		category,
		size,
		asin,
		courier_status,
		qty,
		currency,
		amount,
		ship_city,
		ship_state,
		ship_postal_code,
		ship_country,
		b2b,
		fulfilled_by
FROM
	sales_data
