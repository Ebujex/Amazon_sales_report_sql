/*
=========================================================
Data Quality Checks
=========================================================
Purpose:
This script performs initial data quality checks on the
raw Amazon sales dataset in the bronze layer.

Checks Included:
- Duplicate order and product checks
- Leading and trailing whitespace checks
- Distinct value checks for categorical fields
- SKU and style consistency validation
- ASIN length validation
=========================================================
*/


/* Check for duplicate order and SKU combinations */
SELECT
    order_ID,
    sku,
    COUNT(*) AS duplicate_count
FROM bronze.amazon_sales
GROUP BY
    order_ID,
    sku
HAVING COUNT(*) > 1;


/* Check for leading and trailing spaces in order_ID */
SELECT
    order_ID
FROM bronze.amazon_sales
WHERE order_ID <> TRIM(order_ID);


/* Check for leading and trailing spaces in fulfilment */
SELECT
    fulfilment
FROM bronze.amazon_sales
WHERE fulfilment <> TRIM(fulfilment);


/* Review unique values in fulfilment */
SELECT DISTINCT
    fulfilment
FROM bronze.amazon_sales;


/* Review unique values in sales_channel */
SELECT DISTINCT
    sales_channel
FROM bronze.amazon_sales;


/* Review unique values in ship_service_level */
SELECT DISTINCT
    ship_service_level
FROM bronze.amazon_sales;


/* Validate consistency between SKU prefix and style */
WITH style_check AS (
    SELECT
        style,
        sku,
        CASE
            WHEN CHARINDEX('-', sku) > 0
                THEN LEFT(sku, CHARINDEX('-', sku) - 1)
            ELSE sku
        END AS extracted_style
    FROM bronze.amazon_sales
)
SELECT
    *
FROM style_check
WHERE style <> extracted_style;


/* Check for ASIN values longer than the expected 10-character format */
SELECT
    asin
FROM bronze.amazon_sales
WHERE LEN(asin) > 10;
